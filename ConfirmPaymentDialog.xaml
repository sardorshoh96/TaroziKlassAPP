<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaroziAPP.ConfirmPaymentDialog"
             Title=""
             BackgroundColor="#80000000">

    <Grid>
        <!-- Dialog Background -->
        <Frame BackgroundColor="White" 
               CornerRadius="20" 
               Padding="32"
               HasShadow="True"
               Margin="32"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="360">
            
            <StackLayout Spacing="24">
                
                <!-- Icon -->
                <Label Text="✅"
                       FontSize="64"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <!-- Title -->
                <Label Text="To'lovni tasdiqlash" 
                       FontSize="24" 
                       FontAttributes="Bold"
                       TextColor="#2E3192"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <!-- Details Frame -->
                <Frame BackgroundColor="#f8f9fa" 
                       CornerRadius="12" 
                       Padding="20"
                       HasShadow="False">
                    <StackLayout Spacing="12">
                        <!-- Weight -->
                        <Grid>
                            <Label Text="Og'irlik:" 
                                   FontSize="16" 
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Label x:Name="WeightLabel"
                                   Text="0.00 kg" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Separator -->
                        <BoxView HeightRequest="1" 
                                 BackgroundColor="#dee2e6" 
                                 Margin="0,4"/>

                        <!-- Should Pay -->
                        <Grid>
                            <Label Text="To'lanishi kerak:" 
                                   FontSize="16" 
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Label x:Name="ShouldPayLabel"
                                   Text="0 so'm" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Paid -->
                        <Grid>
                            <Label Text="To'landi:" 
                                   FontSize="16" 
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Label x:Name="PaidLabel"
                                   Text="0 so'm" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#28a745"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- Question -->
                <Label Text="To'lovni tasdiqlaysizmi?"
                       FontSize="18"
                       TextColor="#333"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"/>

                <!-- Buttons -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Cancel Button -->
                    <Button Grid.Column="0"
                            Text="Yo'q"
                            BackgroundColor="#6c757d"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnCancelClicked"/>
                    
                    <!-- Confirm Button -->
                    <Button Grid.Column="1"
                            Text="Ha"
                            BackgroundColor="#2E3192"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnConfirmClicked"/>
                </Grid>
                
            </StackLayout>
        </Frame>
    </Grid>

</ContentPage>

