<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaroziAPP.SettingsPage"
             Padding="0"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1BFFFF" Offset="0"/>
            <GradientStop Color="#2E3192" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <!-- Content -->
    <ScrollView Padding="0">
        <VerticalStackLayout Padding="24,30,24,48"
                             Spacing="24">

            <!-- Header: chap - orqaga tugma, o'ng - app nomi va versiya -->
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Button Grid.Column="0"
                        Text="← Asosiy menyu"
                        HorizontalOptions="Start"
                        Padding="18,10" 
                        MaximumWidthRequest="400"
                        BackgroundColor="#2E3192"
                        TextColor="White"
                        FontSize="14"
                        CornerRadius="18"
                        Clicked="OnBackClicked"/>

                <StackLayout Grid.Column="1" Orientation="Vertical" Spacing="0"
                             HorizontalOptions="End" VerticalOptions="Center">
                    <Label Text="Tarozi Klass"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#2E3192"
                           HorizontalOptions="End"/>
                    <Label x:Name="AppVersionLabel"
                           FontSize="12"
                           TextColor="#607D8B"
                           HorizontalOptions="End"/>
                </StackLayout>
            </Grid>
            
            <Button Text="Advanced sozlamalar"
                    x:Name="advenceSetting"
                    x:FieldModifier="public"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    IsVisible="False"
                    Padding="16,10"
                    BackgroundColor="#2E3192"
                    TextColor="White"
                    CornerRadius="14"
                    Clicked="OnAdvancedSettingsClicked"/>



            <Frame BackgroundColor="#FFFFFFEE"
                   CornerRadius="24"
                   Padding="20"
                   HasShadow="True">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="18">
                    <StackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                        <Label Text="🏪 Kiosk rejimi"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1A237E"/>
                        <Label x:Name="KioskStatusLabel" 
                               Text="O'chirilgan" 
                               FontSize="14" 
                               TextColor="#607D8B"/>
                    </StackLayout>
                    <Switch Grid.Row="0" Grid.Column="1" 
                            x:Name="KioskSwitch"
                            OnColor="#2E3192"
                            ThumbColor="White"
                            Toggled="OnKioskToggled"/>

                    <StackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                        <Label Text="📍 Manzil"
                               x:Name="setting1"
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#1A237E">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="1" 
                                                      Tapped="TapGestureRecognizer_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <Label x:Name="AddressLabel" 
                               Text="Manzil kiritilmagan" 
                               FontSize="14" 
                               TextColor="#607D8B"/>
                    </StackLayout>
                    <Button Grid.Row="1" Grid.Column="1"
                            x:Name="AddressButton"
                            Text="➕" 
                            BackgroundColor="#2E3192"
                            TextColor="White"
                            FontSize="18"
                            CornerRadius="16"
                            WidthRequest="48"
                            HeightRequest="48"
                            Clicked="OnAddressClicked"/>

                </Grid>
            </Frame>

            <Frame BackgroundColor="#FFFFFFEE"
                   CornerRadius="24"
                   Padding="20"
                   HasShadow="True">
                <StackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto"
                          VerticalOptions="Center">
                        <StackLayout Spacing="4">
                            <Label Text="Narxlar ro'yxati" 
                                   FontSize="20" 
                                   FontAttributes="Bold"
                                   TextColor="#1A237E"/>
                            <Label Text="Kilo bo'yicha narxlarni boshqarish"
                                   FontSize="13"
                                   TextColor="#607D8B"/>
                        </StackLayout>
                        
                    </Grid>

                    <CollectionView x:Name="PriceListView" 
                                    BackgroundColor="Transparent">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F5F7FF"
                                        Stroke="#E0E7FF"
                                        StrokeThickness="1"
                                        Padding="16"
                                        Margin="0,6">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="16"
                                          VerticalOptions="Center">
                                        <StackLayout Spacing="6">
                                            <Label Text="{Binding WeightText}" 
                                                   FontSize="18" 
                                                   FontAttributes="Bold"
                                                   TextColor="#1A237E"/>
                                            <Label Text="{Binding PriceText}" 
                                                   FontSize="15" 
                                                   TextColor="#2E3192"/>
                                        </StackLayout>
                                        
                                        <StackLayout Grid.Column="1" 
                                                     Orientation="Horizontal" 
                                                     Spacing="8">
                                            <Button Text="✏️" 
                                                    BackgroundColor="#2E3192"
                                                    TextColor="White"
                                                    FontSize="16"
                                                    CornerRadius="14"
                                                    WidthRequest="46"
                                                    HeightRequest="46"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="OnEditPriceClicked"/>
                                            <Button Text="🗑️" 
                                                    BackgroundColor="#EF5350"
                                                    TextColor="White"
                                                    FontSize="16"
                                                    CornerRadius="14"
                                                    WidthRequest="46"
                                                    HeightRequest="46"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="OnDeletePriceClicked"
                                                    IsVisible="{Binding IsDeletable}"/>
                                            <Button Text="➕" 
                                                    BackgroundColor="#00BFA5"
                                                    TextColor="White"
                                                    FontSize="18"
                                                    CornerRadius="14"
                                                    WidthRequest="46"
                                                    HeightRequest="46"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="OnAddPriceClicked"
                                                    IsVisible="{Binding IsLastItem}"/>
                                        </StackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Frame>

            <Frame x:Name="EmptyStateFrame"
                   BackgroundColor="#FFFFFFEE" 
                   CornerRadius="24" 
                   Padding="32"
                   HasShadow="True"
                   IsVisible="False">
                <StackLayout HorizontalOptions="Center" Spacing="12">
                    <Label Text="📋" 
                           FontSize="54" 
                           HorizontalOptions="Center"/>
                    <Label Text="Narxlar ro'yxati bo'sh" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="#1A237E"
                           HorizontalOptions="Center"/>
                    <Label Text="Yangi narx qo'shish uchun yuqoridagi &quot;Yangi narx&quot; tugmasini bosing."
                           FontSize="14" 
                           TextColor="#607D8B"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"/>
                </StackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
